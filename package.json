{
  "name": "rizz-me-if-you-can-codex",
  "type": "module",
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=7.0.0",
    "npm": "please use pnpm"
  },
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "build": "node scripts/run-pnpm.cjs -r --if-present run build",
    "typecheck": "node scripts/run-pnpm.cjs -r --if-present run typecheck",
    "check": "node scripts/run-pnpm.cjs -r --if-present run check",
    "fix": "node scripts/run-pnpm.cjs -r --if-present run fix",
    "bindgen": "caffeine-bindgen --did-file ./src/backend/dist/backend.did --out-dir ./src/frontend/src --actor-interface-file --force"
  },
  "devDependencies": {
    "sharp": "^0.34.4"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@caffeineai/core-infrastructure": "^0.3.0"
  }
}
